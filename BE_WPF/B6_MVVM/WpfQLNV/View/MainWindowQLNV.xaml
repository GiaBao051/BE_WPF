<Window x:Class="WpfQLNV.View.MainWindowQLNV"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WpfQLNV.ViewModels"
        mc:Ignorable="d"
        Title="MainWindowQLNV" Height="450" Width="800">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- TreeView Phòng ban -->
        <StackPanel Grid.Column="0">
            <TextBlock Text="Phòng ban" FontWeight="Bold"/>
            <TreeView ItemsSource="{Binding Departments}" SelectedItemChanged="TreeView_SelectedItemChanged">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Employees}">
                        <TextBlock Text="{Binding Name}"/>
                        <HierarchicalDataTemplate.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullName}"/>
                            </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            <TextBox Text="{Binding NewDepartmentName, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>
            <Button Content="Thêm phòng ban" Command="{Binding AddDepartmentCommand}" Margin="0,5,0,0"/>
            <Button Content="Xóa phòng ban" Command="{Binding RemoveDepartmentCommand}" Margin="0,5,0,0"/>
        </StackPanel>
        <!-- Thông tin nhân viên -->
        <StackPanel Grid.Column="1" Margin="20,0,0,0">
            <TextBlock Text="HỒ SƠ NHÂN VIÊN" FontWeight="Bold" FontSize="16" Foreground="Blue"/>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Mã số" Width="60"/>
                <TextBox Width="150" Text="{Binding EmployeeId}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Họ tên" Width="60"/>
                <TextBox Width="150" Text="{Binding EmployeeName}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Địa chỉ" Width="60"/>
                <TextBox Width="150" Text="{Binding EmployeeAddress}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Phòng ban" Width="60"/>
                <ComboBox Width="150" ItemsSource="{Binding Departments}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedDepartment}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Thêm" Width="80" Command="{Binding AddEmployeeCommand}"/>
                <Button Content="Thoát" Width="80" Margin="10,0,0,0" Click="Exit_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
