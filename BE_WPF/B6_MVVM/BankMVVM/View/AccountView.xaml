<Window x:Class="BankMVVM.Views.AccountView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BankMVVM.ViewModels"
        Title="Quản lý tài khoản ngân hàng"
        Height="550" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:AccountViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Grid.Row="0"
                   Text="DANH SÁCH TÀI KHOẢN NGÂN HÀNG"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="DarkBlue"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Form nhập liệu -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Số tài khoản:" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox Grid.Column="1"
         Text="{Binding InputAccountNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
         Margin="5"/>

            <TextBlock Grid.Column="2" Text="Tên khách hàng:" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox Grid.Column="3"
         Text="{Binding InputCustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
         Margin="5"/>

            <TextBlock Grid.Row="1" Text="Địa chỉ:" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox Grid.Row="1" Grid.Column="1"
         Text="{Binding InputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
         Margin="5"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="Thành phố:" VerticalAlignment="Center" Margin="0,5"/>
            <ComboBox Grid.Row="1" Grid.Column="3"
          ItemsSource="{Binding Cities}"
          SelectedItem="{Binding InputCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          Margin="5"/>

            <TextBlock Grid.Row="2" Text="Số tiền:" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox Grid.Row="2" Grid.Column="1"
         Text="{Binding InputBalance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
         Margin="5"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Accounts}"
                  SelectedItem="{Binding SelectedAccount}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="0,10,0,10"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="50"/>
                <DataGridTextColumn Header="Số TK" Binding="{Binding AccountNumber}" Width="100"/>
                <DataGridTextColumn Header="Tên KH" Binding="{Binding CustomerName}" Width="200"/>
                <DataGridTextColumn Header="Địa chỉ" Binding="{Binding Address}" Width="200"/>
                <DataGridTextColumn Header="Thành phố" Binding="{Binding City}" Width="100"/>
                <DataGridTextColumn Header="Số tiền" Binding="{Binding Balance, StringFormat=N0}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Tổng tiền -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5">
            <TextBlock Text="Tổng tiền: " FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding TotalBalance, StringFormat=N0}" Foreground="DarkRed" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Nút thao tác -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">
            <Button Content="{Binding AddButtonText}"
                    Width="80"
                    Height="30"
                    Margin="5,0"
                    Command="{Binding AddCommand}"/>
            <Button Content="Lưu"
                    Width="80"
                    Height="30"
                    Margin="5,0"
                    Command="{Binding SaveCommand}"/>
            <Button Content="{Binding EditButtonText}"
                    Width="80"
                    Height="30"
                    Margin="5,0"
                    Command="{Binding EditCommand}"/>
            <Button Content="Xóa"
                    Width="80"
                    Height="30"
                    Margin="5,0"
                    Command="{Binding DeleteCommand}"/>
        </StackPanel>
    </Grid>
</Window>
